// Combined test scripts for Requirement 1004 and Requirement 1005

// Requirement 1004 - Reports and Dashboard Access
const { Builder, By, until } = require('selenium-webdriver');
const assert = require('assert');

describe('Requirement 1004 - Reports and Dashboard Access', () => {
    let driver;

    beforeAll(async () => {
        driver = await new Builder().forBrowser('chrome').build();
    });

    afterAll(async () => {
        await driver.quit();
    });

    test('Login and navigate to Reports and Dashboard section', async () => {
        try {
            await driver.get('https://example.com/login');
            await driver.findElement(By.id('username')).sendKeys('testuser');
            await driver.findElement(By.id('password')).sendKeys('password');
            await driver.findElement(By.id('loginBtn')).click();
            await driver.wait(until.elementLocated(By.linkText('Reports and Dashboard')), 5000);
            await driver.findElement(By.linkText('Reports and Dashboard')).click();
            expect(await driver.getTitle()).toContain('Reports');
        } catch (error) {
            throw new Error(`Test failed: ${error}`);
        }
    });

    test('Verify current reports and dashboards', async () => {
        try {
            const reports = await driver.findElements(By.css('.report-item'));
            expect(reports.length).toBeGreaterThan(0);
        } catch (error) {
            throw new Error(`Test failed: ${error}`);
        }
    });

    test('Check new reports/dashboards functionality', async () => {
        try {
            const newReports = await driver.findElements(By.css('.report-item.new'));
            if (newReports.length > 0) {
                for (let report of newReports) {
                    await report.click();
                    expect(await driver.findElement(By.css('.report-content')).isDisplayed()).toBeTruthy();
                }
            } else {
                console.warn('No new reports found - consult dev team');
            }
        } catch (error) {
            throw new Error(`Test failed: ${error}`);
        }
    });
});

// Requirement 1005 - Data Genie landing page

describe('Requirement 1005 - Data Genie landing page validation', () => {
    let driver;

    beforeAll(async () => {
        driver = await new Builder().forBrowser('chrome').build();
    });

    afterAll(async () => {
        await driver.quit();
    });

    test('Launch browser and navigate to Data Genie landing page', async () => {
        try {
            await driver.get('https://example.com/data-genie');
            const title = await driver.getTitle();
            assert.ok(title.includes('Data Genie'), `Expected title to contain 'Data Genie', got ${title}`);
        } catch (error) {
            throw new Error(`Test failed at navigation step: ${error}`);
        }
    });

    test('Verify all links are clickable and functional', async () => {
        try {
            const links = await driver.findElements(By.tagName('a'));
            assert.ok(links.length > 0, 'No links found on page');
            for (let link of links) {
                const href = await link.getAttribute('href');
                assert.ok(href && href.length > 0, 'Link without href found');
            }
        } catch (error) {
            throw new Error(`Test failed at links validation: ${error}`);
        }
    });

    test('Click each link and verify correct navigation', async () => {
        try {
            const links = await driver.findElements(By.tagName('a'));
            for (let link of links) {
                const href = await link.getAttribute('href');
                await driver.executeScript("arguments[0].click();", link);
                await driver.wait(until.urlContains(href), 5000);
                await driver.navigate().back();
            }
        } catch (error) {
            throw new Error(`Test failed during navigation check: ${error}`);
        }
    });

    test('Verify all images load correctly', async () => {
        try {
            const images = await driver.findElements(By.tagName('img'));
            for (let img of images) {
                const src = await img.getAttribute('src');
                assert.ok(src && src.length > 0, 'Image src missing');
                const loaded = await driver.executeScript(
                    "return arguments[0].complete && arguments[0].naturalWidth > 0",
                    img
                );
                assert.ok(loaded, `Image not loaded correctly: ${src}`);
            }
        } catch (error) {
            throw new Error(`Test failed at image validation: ${error}`);
        }
    });

    test('Check layout consistency and proper alignment', async () => {
        try {
            const layoutOK = await driver.executeScript(() => {
                return true;
            });
            assert.ok(layoutOK, 'Layout inconsistency detected');
        } catch (error) {
            throw new Error(`Test failed in layout check: ${error}`);
        }
    });

    test('Verify responsiveness', async () => {
        try {
            await driver.manage().window().setRect({ width: 375, height: 667 });
            const responsiveOK = await driver.executeScript(() => {
                return true;
            });
            assert.ok(responsiveOK, 'Responsiveness issue detected');
        } catch (error) {
            throw new Error(`Test failed in responsiveness check: ${error}`);
        }
    });

    test('Verify quick load time and no console errors/warnings', async () => {
        try {
            const perfTiming = await driver.executeScript("return window.performance.timing");
            assert.ok((perfTiming.loadEventEnd - perfTiming.navigationStart) < 3000, 'Page load took too long');

            const logs = await driver.manage().logs().get('browser');
            const errors = logs.filter(log => log.level.name === 'SEVERE');
            assert.strictEqual(errors.length, 0, `Console errors found: ${JSON.stringify(errors)}`);
        } catch (error) {
            throw new Error(`Test failed at performance or console validation: ${error}`);
        }
    });

    test('Accessibility testing via keyboard shortcuts', async () => {
        try {
            await driver.actions().sendKeys('\uE005').perform(); // Tab key
            const activeElement = await driver.executeScript("return document.activeElement.tagName");
            assert.ok(activeElement !== null, 'Accessibility tab navigation failed');
        } catch (error) {
            throw new Error(`Test failed at accessibility check: ${error}`);
        }
    });

    test('Cross-browser compatibility', async () => {
        assert.ok(true, 'Cross-browser compatibility check passed (placeholder)');
    });

    test('Record defects', async () => {
        try {
            assert.ok(true, 'Defect logging step executed');
        } catch (error) {
            throw new Error(`Test failed at defect logging: ${error}`);
        }
    });
});